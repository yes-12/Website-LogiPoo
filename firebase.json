{
  "hosting": {
    "public": ".", 
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/projects",
        "destination": "/projects.html"
      },
      {
        "source": "/taxes-game",
        "destination": "/Projects/TaxesTheGame.html"
      },
      {
        "source": "/artworks",
        "destination": "/artworks.html"
      }
    ]
  }
}